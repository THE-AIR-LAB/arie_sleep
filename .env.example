# ─────────────────────────────────────────────────────────────────────────────
# Sleep Assistant — environment variables
# Copy to .env.local for local dev, or add these in the Vercel project settings.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key (public) and the service-role key (server-only secret).
NEXT_PUBLIC_AIRLAB_SUPABASE_URL=
NEXT_PUBLIC_AIRLAB_SUPABASE_ANON_KEY=
AIRLAB_SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Primary key (AIRLAB_OPENAI_API_KEY preferred; OPENAI_API_KEY is the fallback).
AIRLAB_OPENAI_API_KEY=
# OPENAI_API_KEY=

# Fine-tuned sleep/triage model id used by /api/chat/sleep/ft-1.
# A default is hard-coded in the route; override here if you have your own.
AIRLAB_FT_SLEEP_STAGE_1=ft:gpt-4.1-2025-04-14:personal:triage-stateful2:DSEr4D6R
# Optional fine-tune fallbacks:
# AIRLAB_OPENAI_FINE_TUNED_MODEL=
# OPENAI_FINE_TUNED_MODEL=
# OPENAI_ASSISTANT_MODEL=

# ── Clerk (auth) ────────────────────────────────────────────────────────────
# These project-specific AIR_* names are bridged to the standard Clerk names
# by next.config.ts / proxy.ts so this app can deploy alongside another
# Clerk project without env collisions.
NEXT_PUBLIC_AIR_CLERK_PUBLISHABLE_KEY=
AIR_CLERK_SECRET_KEY=
# Standard fallbacks (used if the AIR_* variants are unset):
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# ── Headless / cross-origin clients (standalone React web, React Native) ─────
# Origins allowed to call the API cross-origin (comma-separated). Needed when a
# separate React app (e.g. Vite on http://localhost:5173) calls these routes.
# localhost/127.0.0.1 are always allowed in development.
AIRLAB_ALLOWED_ORIGINS=http://localhost:5173
# Callers Clerk will accept a Bearer session token from (comma-separated):
# deployment URL, dev origin, and/or a native app identifier.
AIRLAB_AUTHORIZED_PARTIES=http://localhost:5173,http://localhost:3000

# ── Site / misc ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_TEST_MODE=          # set to 1 to use the cookie-based test persona instead of Clerk
